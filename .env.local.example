# ──────────────────────────────────────────────────────────────
# OpenAI — AI analyzer vision + reasoning pipeline
# ──────────────────────────────────────────────────────────────
# Get a key at https://platform.openai.com/api-keys.
# Used for gpt-4o (vision extraction) + o4-mini (reasoning analysis).
# If left empty, /api/analyze returns a realistic mocked response so the UI
# remains developable without a key.
OPENAI_API_KEY=

# ──────────────────────────────────────────────────────────────
# Perplexity Sonar — AI coach (fallback / web-research)
# ──────────────────────────────────────────────────────────────
# Get a key at https://docs.perplexity.ai/ (Settings → API Keys).
PERPLEXITY_API_KEY=

# ──────────────────────────────────────────────────────────────
# Clerk — authentication
# ──────────────────────────────────────────────────────────────
# https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ──────────────────────────────────────────────────────────────
# Stripe — subscriptions
# ──────────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# The price ID for the subscription plan (price_...)
STRIPE_PRICE_ID=
# https://dashboard.stripe.com/webhooks → "Signing secret"
STRIPE_WEBHOOK_SECRET=

# ──────────────────────────────────────────────────────────────
# Supabase — database
# ──────────────────────────────────────────────────────────────
# https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only, NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Prisma (Supabase Postgres connection — copy from Supabase → Project Settings → Database → Connection string)
# Pooled (for runtime, port 6543, with ?pgbouncer=true&connection_limit=1):
DATABASE_URL=
# Direct (for migrations, port 5432):
DIRECT_URL=
